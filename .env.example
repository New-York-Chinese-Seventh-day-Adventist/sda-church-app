# Default language for the app (e.g., en, zh, zh-cn, es)
EXPO_PUBLIC_DEFAULT_LANGUAGE=en

# Church Contact Information
EXPO_PUBLIC_CHURCH_NAME="Your Church Name"
EXPO_PUBLIC_CHURCH_ADDRESS="123 Church St, City, State, Zip Code"
EXPO_PUBLIC_CHURCH_PHONE="(555) 000-0000"
EXPO_PUBLIC_CHURCH_EMAIL="info@example.org"

# External Links
EXPO_PUBLIC_ONLINE_GIVING_LINK="https://adventistgiving.org/donate/YOURCHURCHID"

# The handle found in the YouTube channel URL without the @ prefix
# e.g. https://www.youtube.com/@newyorkchinesesdachurch1334/streams
# would have the handle "newyorkchinesesdachurch1334"
EXPO_PUBLIC_YOUTUBE_CHANNEL_HANDLE="YourChannelHandle"