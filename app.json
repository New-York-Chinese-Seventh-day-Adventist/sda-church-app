{
  "expo": {
    "name": "sda-church-app",
    "slug": "sda-church-app",
    "version": "0.13.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-1024x1024.png",
    "scheme": "sdachurchapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon-2048x2048.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/sda-church-app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon-48x48.png",
      "display": "standalone",
      "description": "Seventh-day Adventist church community application.",
      "shortName": "SDA Church",
      "lang": "en"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.sdachurchapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-1024x1024.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.sdachurchapp"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "./withAndroidSDKOverride"
    ]
  }
}
