{
  "expo": {
    "name": "sda-church-app",
    "slug": "sda-church-app",
    "version": "0.8.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sdachurchapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/sda-church-app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "display": "standalone",
      "themeColor": "#0061A4",
      "backgroundColor": "#ffffff",
      "description": "Seventh-day Adventist church community application.",
      "shortName": "SDA Church",
      "lang": "en"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.sdachurchapp",
      "minimumOsVersion": "15.0"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.sdachurchapp"
    },
    "plugins": ["expo-router", "expo-localization", "./withAndroidSDKOverride"]
  }
}
